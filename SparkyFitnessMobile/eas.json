{
    "cli": {
        "version": ">= 3.0.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "env": {
                "APP_VARIANT": "development"
            },
            "developmentClient": true,
            "distribution": "internal"
        },
        "preview": {
            "env": {
                "APP_VARIANT": "preview"
            },
            "distribution": "internal"
        },
        "production": {
            "env": {
                "APP_VARIANT": "production"
            },
            "autoIncrement": true,
            "distribution": "internal",
            "android": {
                "buildType": "app-bundle"
            },
            "ios": {
                "resourceClass": "medium",
                "withoutCredentials": true
            }
        }
    },
    "submit": {
        "production": {
            "ios": {
                "ascAppId": "6757314392"
            }
        }
    }
}