{
  "expo": {
    "name": "SparkyFitnessMobile",
    "slug": "sparkyfitnessmobile",
    "version": "1.4.3",
    "scheme": "sparkyfitnessmobile",
    "orientation": "portrait",
    "icon": "./assets/icons/appstore.png",
    "userInterfaceStyle": "automatic",
    "plugins": [
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "SparkyFitness reads Health data (such as activity, workouts, and body measurements) to display it in the app and sync it to your self-hosted SparkyFitness server.",
          "background": true
        }
      ],
      "expo-health-connect",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "minSdkVersion": 26
          }
        }
      ],
      "react-native-health-connect",
      "expo-web-browser",
      "expo-font",
      "expo-asset",
      "expo-background-task",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "SparkyFitness needs access to your camera to scan food barcodes and labels.",
          "recordAudioAndroid": false,
          "barcodeScannerEnabled": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#e2e2e2",
          "imageWidth": 200,
          "image": "./assets/images/splash.png",
          "dark": {
            "backgroundColor": "#232323",
            "image": "./assets/images/splash.png"
          }
        }
      ],
      [
        "expo-notifications"
      ]
    ],
    "experiments": {
      "reactCompiler": true,
      "autolinkingModuleResolution": true
    },
    "extra": {
      "APP_VARIANT": "dev",
      "iosAppGroup": "group.6827d1df5271d2c4.5",
      "thorethyBundle": "app.sweetpotato2633.coral4840",
      "thorethyWidgetBundle": "app.sweetpotato2633.coral4840.widget",
      "eas": {
        "projectId": "4551af79-1f16-4c11-87d9-629093b5d472"
      }
    },
    "owner": "thorethy4"
  }
}
