{
  "name": "sparkyfitnessmobile",
  "version": "1.4.3",
  "private": true,
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "expo lint",
    "start": "expo start",
    "test": "jest",
    "test:run": "jest",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "typecheck": "tsc --noEmit",
    "validate": "pnpm run typecheck && pnpm run lint"
  },
  "dependencies": {
    "@bacons/apple-targets": "^4.0.6",
    "@bottom-tabs/react-navigation": "^1.2.0",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@kingstinct/react-native-healthkit": "^13.3.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-clipboard/clipboard": "^1.16.0",
    "@react-navigation/bottom-tabs": "^7.15.6",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.4.2",
    "@shopify/react-native-skia": "2.4.18",
    "@tanstack/react-query": "^5.90.20",
    "@workspace/shared": "workspace:*",
    "expo": "~55.0.26",
    "expo-application": "~55.0.15",
    "expo-asset": "~55.0.17",
    "expo-background-task": "~55.0.18",
    "expo-build-properties": "^55.0.14",
    "expo-camera": "~55.0.19",
    "expo-constants": "~55.0.16",
    "expo-dev-client": "^55.0.35",
    "expo-device": "~55.0.17",
    "expo-file-system": "~55.0.22",
    "expo-font": "~55.0.8",
    "expo-haptics": "~55.0.14",
    "expo-health-connect": "^0.1.1",
    "expo-image-picker": "~55.0.20",
    "expo-navigation-bar": "~55.0.13",
    "expo-notifications": "~55.0.23",
    "expo-secure-store": "~55.0.14",
    "expo-sharing": "~55.0.20",
    "expo-splash-screen": "~55.0.21",
    "expo-symbols": "~55.0.9",
    "expo-system-ui": "~55.0.18",
    "expo-task-manager": "~55.0.16",
    "expo-web-browser": "~55.0.16",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-bottom-tabs": "^1.2.0",
    "react-native-gesture-handler": "~2.30.1",
    "react-native-health-connect": "^3.5.3",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-nitro-modules": "^0.35.5",
    "react-native-pager-view": "8.0.0",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-toast-message": "^2.3.3",
    "react-native-ui-datepicker": "^3.1.2",
    "react-native-worklets": "0.7.4",
    "tailwindcss": "^4.1.18",
    "uniwind": "^1.7.0",
    "victory-native": "^41.20.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/runtime": "^7.25.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.14",
    "babel-preset-expo": "~55.0.22",
    "eslint": "^9.39.3",
    "eslint-config-expo": "~55.0.1",
    "eslint-plugin-import": "^2.32.0",
    "expo-atlas": "^0.4.0",
    "jest": "~29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "jest-expo": "~55.0.18",
    "prettier": "2.8.8",
    "radon-ide": "^0.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  },
  "jest": {
    "preset": "jest-expo",
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "./jest.setup.js"
    ],
    "testPathIgnorePatterns": [
      "__tests__/hooks/queryTestUtils\\.ts$"
    ],
    "moduleNameMapper": {
      "^@workspace/shared$": "<rootDir>/../shared/src/index.ts",
      "^@babel/runtime/(.*)$": "<rootDir>/node_modules/@babel/runtime/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(?:.pnpm/[^/]+/node_modules/)?((jest-)?react-native|@react-native(-community)?|expo[^/]*|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|@shopify/react-native-skia|react-native-ui-datepicker|@workspace/shared|zod)/)"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "**/*.{ts,tsx,js,jsx}",
      "!**/coverage/**",
      "!**/node_modules/**",
      "!**/babel.config.js",
      "!**/metro.config.js",
      "!**/.prettierrc.js",
      "!**/eslint.config.js",
      "!**/expo-env.d.ts",
      "!**/.expo/**",
      "!**/devdocs/**"
    ]
  }
}
